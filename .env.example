DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_railway_mysql_password
DB_NAME=railway

# Railway also provides these names automatically. The app supports them too:
# MYSQLHOST=mysql.railway.internal
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=your_railway_mysql_password
# MYSQLDATABASE=railway

DB_SYNCHRONIZE=true

# Local development only. Do not set PORT manually on Railway.
# Railway injects its own dynamic PORT at runtime.
PORT=3000
CORS_ORIGIN=https://your-netlify-site.netlify.app
JWT_SECRET=change_me
